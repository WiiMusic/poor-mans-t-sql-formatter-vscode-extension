{
    "name": "VS Code Extension Development",
    "build": {
        "dockerfile": "Containerfile"
    },
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "containerEnv": {
        "GIT_AUTHOR_NAME": "${localEnv:GIT_AUTHOR_NAME}",
        "GIT_AUTHOR_EMAIL": "${localEnv:GIT_AUTHOR_EMAIL}"
    },
    "postCreateCommand": {
        "gitName": "git config --global user.name '${localEnv:GIT_AUTHOR_NAME}'",
        "gitEmail": "git config --global user.email '${localEnv:GIT_AUTHOR_EMAIL}'",
        "npmInstall": "npm install"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "amodio.tsl-problem-matcher",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "mhutchie.git-graph",
                "ms-vscode.extension-test-runner"
            ]
        }
    },
    "forwardPorts": []
}